@page "/main-data/employees/new"
@page "/main-data/employees/{EmployeeId}"

<MainDataForm TViewModel="@EmployeeViewModel" Id="@EmployeeId" Title="@GetTitle" ReturnUri="main-data/employees">
    <FormSection Title="@Localizer["Credentials"]">
        <Field Label="@Localizer["PersonnelNumber"]" Width="100%">
            <TextBox @bind-Value="@context.Item.PersonnelNumber" MaxLength="50" />
        </Field>

        @* TODO *@
        <Field Label="@Localizer["Password"]" Width="100%">
            <TextBox Type="password" MaxLength="30" />
        </Field>
    </FormSection>

    <FormSection Title="@Localizer["PersonalInformation"]">
        <Field Label="@Localizer["FirstName"]" Width="100%">
            <TextBox @bind-Value="@context.Item.Name.FirstName" MaxLength="100" />
        </Field>

        <Field Label="@Localizer["LastName"]" Width="100%">
            <TextBox @bind-Value="@context.Item.Name.LastName" MaxLength="100" />
        </Field>

        <Field Label="@Localizer["Birthday"]" Width="100%">
            @* TODO *@
            <InputDate @bind-Value="@context.Item.Birthday" />
        </Field>
    </FormSection>

    <FormSection Title="@Localizer["ContactInformation"]">
        <Field Label="@Localizer["Emails"]" Width="100%">
            <EditList TItem="@EmployeeEmailViewModel"
                      @bind-Items="@context.Item.Emails"
                      ItemFactory="@(() => EmployeeEmailViewModel.New(context.Item.Id))"
                      Context="email">

                <Inline>
                    <TextBox @bind-Value="@email.Email"
                             MaxLength="50"
                             Width="100%" />
                </Inline>

                <Item>
                    @email.Email
                </Item>
            </EditList>
        </Field>

        <Field Label="@Localizer["PhoneNumbers"]" Width="100%">
            <EditList TItem="@EmployeePhoneNumberViewModel"
                      @bind-Items="@context.Item.PhoneNumbers"
                      ItemFactory="@(() => EmployeePhoneNumberViewModel.New(context.Item.Id))"
                      Context="phoneNumber">

                <Inline>
                    <TextBox @bind-Value="@phoneNumber.PhoneNumber"
                             MaxLength="50"
                             Width="100%" />
                </Inline>

                <Item>
                    @phoneNumber.PhoneNumber
                </Item>
            </EditList>
        </Field>
    </FormSection>

    <FormSection Title="@Localizer["Assignments"]">
        <Field Label="@Localizer["Roles"]" Width="100%">
            <CheckList TItem="@RoleViewModel"
                       Items="@FormService.GetRoles()"
                       CheckCondition="@context.Item.HasRole"
                       OnToggle="@context.Item.ToggleRole"
                       Pageable="@true"
                       PageCount="15"
                       SortOptions="@GetRoleListSortOptions()"
                       Context="role">

                <Item>
                    @role.Name
                    @role.Description
                </Item>
            </CheckList>
        </Field>
    </FormSection>
</MainDataForm>
