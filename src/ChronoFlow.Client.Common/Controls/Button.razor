<button id="@Id"
        type="@Type"
        class="c-button"
        title="@Tooltip"
        @onclick="@OnClick">

    @if (IconLeft != null)
    {
        <i class="@IconLeft" style="@(IconLeftSize != null ? $"font-size:{IconLeftSize};" : null)"></i>
    }

    @if (ChildContent != null)
    {
        @ChildContent
    }
</button>
