@typeparam TViewModel

@if (Item == null)
    return;

<div class="md-form">
    <Form Item="@Item">
        @{
            var mainDataFormContext = new MainDataFormContext<TViewModel>(Item, IsBusy, IsNew, context);
            var subtitle = GetSubtitle();
        }

        <header>
            <section>
                <Button Class="squared"
                        IconLeft="bi bi-arrow-left"
                        OnClick="@NavigateBack"
                        Disabled="@IsBusy" />

                <div>
                    @Title(mainDataFormContext)
                </div>
            </section>

            @if (subtitle != null)
            {
                <section>
                    @subtitle
                </section>
            }
        </header>

        <main>
            @ChildContent(mainDataFormContext)
        </main>

        <footer>
            <Button Class="alt" IconLeft="bi bi-check-2" OnClick="@SaveAsync" Disabled="@IsBusy">
                @Localizer["Save"]
            </Button>
        </footer>
    </Form>
</div>
